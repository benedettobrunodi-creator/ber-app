generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique @db.VarChar(255)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  name         String   @db.VarChar(255)
  role         String   @default("campo") @db.VarChar(50)
  phone        String?  @db.VarChar(20)
  avatarUrl    String?  @map("avatar_url")
  pushToken    String?  @map("push_token")
  isActive     Boolean  @default(true) @map("is_active")
  permissions  Json     @default("{}")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at")

  // Relations
  coordinatedObras Obra[]             @relation("ObraCoordinator")
  obraMembers      ObraMember[]
  assignedTasks    ObraTask[]         @relation("TaskAssignee")
  createdTasks     ObraTask[]         @relation("TaskCreator")
  proposals        Proposal[]
  meetingsCreated  Meeting[]
  announcements    Announcement[]
  announcementReads AnnouncementRead[]
  chatRoomMembers  ChatRoomMember[]
  chatMessages     ChatMessage[]
  photos           Photo[]
  photoComments    PhotoComment[]
  notifications    Notification[]
  timeEntries      TimeEntry[]
  createdChecklists  Checklist[]     @relation("ChecklistCreator")
  responsibleItems   ChecklistItem[] @relation("ChecklistItemResponsible")
  answeredItems      ChecklistItem[] @relation("ChecklistItemAnswerer")
  canteiroCreated    CanteiroChecklist[]     @relation("CanteiroCreator")
  canteiroApproved   CanteiroChecklist[]     @relation("CanteiroApprover")
  canteiroAnswered   CanteiroChecklistItem[] @relation("CanteiroItemAnswerer")
  aprsCreated      APR[]               @relation("APRCreator")
  aprsApproved     APR[]               @relation("APRApprover")
  epiControls      EPIControl[]        @relation("EPIUser")
  incidentsReported Incident[]         @relation("IncidentReporter")
  incidentsInjured  Incident[]         @relation("IncidentInjured")
  trainings        Training[]          @relation("TrainingUser")
  sequenciamentosCreated ObraSequenciamento[] @relation("SeqCreator")
  etapasSubmitted  ObraEtapa[]         @relation("EtapaSubmitter")
  etapasApproved   ObraEtapa[]         @relation("EtapaApprover")
  etapasRejected   ObraEtapa[]         @relation("EtapaRejecter")
  instrucoesCreated  InstrucaoTecnica[] @relation("ITCreator")
  instrucoesUpdated  InstrucaoTecnica[] @relation("ITUpdater")
  recebimentosRegistrados RecebimentoMaterial[] @relation("RecebimentoRegistrador")
  faseHistoryChanged    ObraFaseHistory[]    @relation("FaseHistoryChanger")
  obraFaseUpdated       Obra[]               @relation("ObraFaseUpdater")
  conductedTouchpoints  ClientTouchpoint[]   @relation("TouchpointConductor")
  touchpointNextActions ClientTouchpoint[]   @relation("TouchpointNextOwner")
  createdTouchpoints    ClientTouchpoint[]   @relation("TouchpointCreator")
  createdPunchLists     PunchList[]          @relation("PunchListCreator")
  punchListItems        PunchListItem[]      @relation("PunchListResponsible")
  etapaEditRequests     EtapaEditRequest[]   @relation("EtapaEditRequester")
  etapaEditResolved     EtapaEditRequest[]   @relation("EtapaEditResolver")
  filledFvs             ObraFvs[]            @relation("FvsFiller")
  gestorFvs             ObraFvs[]            @relation("FvsGestorApprover")
  coordFvs              ObraFvs[]            @relation("FvsCoordApprover")
  rejectedFvs           ObraFvs[]            @relation("FvsRejector")
  filledFvsItems        ObraFvsItem[]        @relation("FvsItemFiller")
  filledBerChecklists   ObraBerChecklist[]   @relation("BerChecklistFiller")
  fotosEnviadas         ObraFoto[]           @relation("FotoAutor")
  filledBerItems        ObraBerChecklistItem[] @relation("BerChecklistItemFiller")
  dreUpdates            DreValue[]             @relation("DreUpdater")
  alocacoes             Alocacao[]             @relation("AlocacaoUser")
  recursosExternosCriados RecursoExterno[]     @relation("RecursoExternoCreator")
  customRole            CustomRole?            @relation(fields: [customRoleId], references: [id])
  customRoleId          String?                @map("custom_role_id") @db.Uuid
  orcamentosResponsavel Orcamento[]            @relation("OrcResp")
  orcamentosCriados     Orcamento[]            @relation("OrcCriador")

  @@map("users")
}

model CustomRole {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique @db.VarChar(100)
  description String?  @db.VarChar(255)
  permissions Json     @default("{}")
  isSystem    Boolean  @default(false) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")
  users       User[]

  @@map("custom_roles")
}

model Obra {
  id              String    @id @default(uuid()) @db.Uuid
  name            String    @db.VarChar(255)
  client          String?   @db.VarChar(255)
  address         String?
  status          String    @default("em_andamento") @db.VarChar(50)
  startDate       DateTime? @map("start_date") @db.Date
  expectedEndDate DateTime? @map("expected_end_date") @db.Date
  actualEndDate   DateTime? @map("actual_end_date") @db.Date
  progressPercent Int       @default(0) @map("progress_percent")
  coordinatorId   String?   @map("coordinator_id") @db.Uuid
  trelloBoardId   String?   @map("trello_board_id") @db.VarChar(30)
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at")

  fase             String    @default("kickoff_interno") @db.VarChar(50)
  faseUpdatedAt    DateTime? @map("fase_updated_at")
  faseUpdatedById  String?   @map("fase_updated_by") @db.Uuid

  dataInicioProjeto DateTime? @map("data_inicio_projeto") @db.Date
  dataFimProjeto    DateTime? @map("data_fim_projeto") @db.Date
  dataInicioObra    DateTime? @map("data_inicio_obra") @db.Date
  dataFimObra       DateTime? @map("data_fim_obra") @db.Date

  // Relations
  coordinator User? @relation("ObraCoordinator", fields: [coordinatorId], references: [id])
  faseUpdatedBy  User?            @relation("ObraFaseUpdater", fields: [faseUpdatedById], references: [id])
  members     ObraMember[]
  tasks       ObraTask[]
  chatRooms   ChatRoom[]
  photos      Photo[]
  timeEntries TimeEntry[]
  checklists  Checklist[]
  canteiroChecklists CanteiroChecklist[]
  aprs        APR[]
  epiControls EPIControl[]
  incidents   Incident[]
  trainings   Training[]
  sequenciamentos ObraSequenciamento[]
  etapas          ObraEtapa[]
  recebimentos    RecebimentoMaterial[]
  faseHistory    ObraFaseHistory[]
  touchpoints    ClientTouchpoint[]
  announcements  Announcement[]
  punchLists     PunchList[]
  obraFvs        ObraFvs[]
  berChecklists  ObraBerChecklist[] @relation("ObraBerChecklists")
  plantas        ObraPlanta[]       @relation("ObraPlantas")
  ambientes      ObraAmbiente[]     @relation("ObraAmbientes")
  fotosObra      ObraFoto[]         @relation("ObraFotos")
  medicoes       Medicao[]          @relation("ObraMedicoes")
  medicaoItens   MedicaoItem[]      @relation("ObraMedicaoItens")
  comprasMetas   ComprasMeta[]
  alocacoes      Alocacao[]    @relation("AlocacaoObra")

  @@map("obras")
}

model ComprasMeta {
  id         String   @id @default(uuid()) @db.Uuid
  obraId     String   @map("obra_id") @db.Uuid
  n          String?  @db.VarChar(20)
  tipo       String   @default("item") @db.VarChar(20)
  categoria  String   @db.VarChar(200)
  descritivo String?  @db.VarChar(500)
  venda      Float    @default(0)
  pctMeta    Float    @default(0.2) @map("pct_meta")
  comprado   Float    @default(0)
  fornecedor  String?  @db.VarChar(500)
  faturamento String?  @db.VarChar(50)
  pacote      Int?
  compradoOk  Boolean  @default(false) @map("comprado_ok")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at")

  obra   Obra          @relation(fields: [obraId], references: [id], onDelete: Cascade)
  splits ComprasSplit[]

  @@index([obraId])
  @@map("compras_metas")
}

model ComprasSplit {
  id            String      @id @default(uuid()) @db.Uuid
  comprasMetaId String      @map("compras_meta_id") @db.Uuid
  fornecedor    String?
  faturamento   String?
  valor         Float       @default(0)
  coTipo        String?     @map("co_tipo") @db.VarChar(10)
  createdAt     DateTime    @default(now()) @map("created_at")

  comprasMeta ComprasMeta @relation(fields: [comprasMetaId], references: [id], onDelete: Cascade)

  @@index([comprasMetaId])
  @@map("compras_splits")
}

model ObraMember {
  id       String   @id @default(uuid()) @db.Uuid
  obraId   String   @map("obra_id") @db.Uuid
  userId   String   @map("user_id") @db.Uuid
  role     String   @default("membro") @db.VarChar(50)
  joinedAt DateTime @default(now()) @map("joined_at")

  obra Obra @relation(fields: [obraId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([obraId, userId])
  @@map("obra_members")
}

model ObraTask {
  id          String    @id @default(uuid()) @db.Uuid
  obraId      String    @map("obra_id") @db.Uuid
  title       String    @db.VarChar(255)
  description String?
  status      String    @default("todo") @db.VarChar(50)
  priority    String    @default("medium") @db.VarChar(20)
  assignedTo  String?   @map("assigned_to") @db.Uuid
  createdBy   String?   @map("created_by") @db.Uuid
  dueDate     DateTime? @map("due_date") @db.Date
  position       Int       @default(0)
  clickupTaskId   String?   @unique @map("clickup_task_id") @db.VarChar(50)
  completedAt     DateTime? @map("completed_at")
  clickupListId   String?   @map("clickup_list_id") @db.VarChar(50)
  clickupListName String?   @map("clickup_list_name") @db.VarChar(255)
  clickupStartDate DateTime? @map("clickup_start_date")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @default(now()) @updatedAt @map("updated_at")

  obra     Obra  @relation(fields: [obraId], references: [id], onDelete: Cascade)
  assignee User? @relation("TaskAssignee", fields: [assignedTo], references: [id])
  creator  User? @relation("TaskCreator", fields: [createdBy], references: [id])

  @@index([obraId])
  @@index([status])
  @@index([assignedTo])
  @@map("obra_tasks")
}

model Proposal {
  id                String    @id @default(uuid()) @db.Uuid
  agendorDealId     String?   @unique @map("agendor_deal_id") @db.VarChar(100)
  clientName        String    @map("client_name") @db.VarChar(255)
  title             String    @db.VarChar(255)
  value             Decimal?  @db.Decimal(15, 2)
  status            String    @default("leads_info") @db.VarChar(50)
  sentDate          DateTime? @map("sent_date") @db.Date
  closedDate        DateTime? @map("closed_date") @db.Date
  notes             String?
  agendorStageName  String?   @map("agendor_stage_name") @db.VarChar(255)
  agendorFunnelName String?   @map("agendor_funnel_name") @db.VarChar(255)
  agendorWebUrl     String?   @map("agendor_web_url") @db.VarChar(500)
  agendorUpdatedAt  DateTime? @map("agendor_updated_at")
  createdBy         String?   @map("created_by") @db.Uuid
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @default(now()) @updatedAt @map("updated_at")

  creator  User?     @relation(fields: [createdBy], references: [id])
  meetings Meeting[]

  @@index([status])
  @@map("proposals")
}

model Meeting {
  id            String   @id @default(uuid()) @db.Uuid
  googleEventId String?  @map("google_event_id") @db.VarChar(255)
  title         String   @db.VarChar(255)
  description   String?
  clientName    String?  @map("client_name") @db.VarChar(255)
  location      String?
  startTime     DateTime @map("start_time")
  endTime       DateTime @map("end_time")
  proposalId    String?  @map("proposal_id") @db.Uuid
  createdBy     String?  @map("created_by") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at")

  proposal Proposal? @relation(fields: [proposalId], references: [id])
  creator  User?     @relation(fields: [createdBy], references: [id])

  @@map("meetings")
}

model Announcement {
  id          String   @id @default(uuid()) @db.Uuid
  title       String   @db.VarChar(255)
  body        String
  category    String   @default("informativo") @db.VarChar(50)
  targetRoles String[] @default(["diretoria", "coordenacao", "gestor", "campo"]) @map("target_roles")
  authorId    String?  @map("author_id") @db.Uuid
  pinned      Boolean  @default(false)
  tipo             String    @default("interno") @db.VarChar(30)
  obraId           String?   @map("obra_id") @db.Uuid
  semanaReferencia DateTime? @map("semana_referencia") @db.Date
  templateData     Json      @default("{}") @map("template_data")
  enviadoCliente   Boolean   @default(false) @map("enviado_cliente")
  enviadoEm        DateTime? @map("enviado_em")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  author User?              @relation(fields: [authorId], references: [id])
  obra   Obra?              @relation(fields: [obraId], references: [id])
  reads  AnnouncementRead[]

  @@index([createdAt(sort: Desc)])
  @@map("announcements")
}

model AnnouncementRead {
  id             String   @id @default(uuid()) @db.Uuid
  announcementId String   @map("announcement_id") @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  readAt         DateTime @default(now()) @map("read_at")

  announcement Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([announcementId, userId])
  @@index([announcementId])
  @@map("announcement_reads")
}

model ChatRoom {
  id        String   @id @default(uuid()) @db.Uuid
  name      String?  @db.VarChar(255)
  type      String   @default("group") @db.VarChar(20)
  obraId    String?  @map("obra_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  obra     Obra?            @relation(fields: [obraId], references: [id])
  members  ChatRoomMember[]
  messages ChatMessage[]

  @@map("chat_rooms")
}

model ChatRoomMember {
  id       String   @id @default(uuid()) @db.Uuid
  roomId   String   @map("room_id") @db.Uuid
  userId   String   @map("user_id") @db.Uuid
  joinedAt DateTime @default(now()) @map("joined_at")

  room ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
  @@map("chat_room_members")
}

model ChatMessage {
  id             String   @id @default(uuid()) @db.Uuid
  roomId         String   @map("room_id") @db.Uuid
  senderId       String?  @map("sender_id") @db.Uuid
  body           String
  attachmentUrl  String?  @map("attachment_url")
  attachmentType String?  @map("attachment_type") @db.VarChar(20)
  readBy         String[] @default([]) @map("read_by") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at")

  room   ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  sender User?    @relation(fields: [senderId], references: [id])

  @@index([roomId, createdAt(sort: Desc)])
  @@map("chat_messages")
}

model Photo {
  id           String   @id @default(uuid()) @db.Uuid
  obraId       String   @map("obra_id") @db.Uuid
  uploadedBy   String?  @map("uploaded_by") @db.Uuid
  imageUrl     String   @map("image_url")
  thumbnailUrl String?  @map("thumbnail_url")
  caption      String?
  createdAt    DateTime @default(now()) @map("created_at")

  obra     Obra           @relation(fields: [obraId], references: [id], onDelete: Cascade)
  uploader User?          @relation(fields: [uploadedBy], references: [id])
  comments PhotoComment[]

  @@index([obraId, createdAt(sort: Desc)])
  @@map("photos")
}

model PhotoComment {
  id        String   @id @default(uuid()) @db.Uuid
  photoId   String   @map("photo_id") @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  body      String
  createdAt DateTime @default(now()) @map("created_at")

  photo Photo @relation(fields: [photoId], references: [id], onDelete: Cascade)
  user  User? @relation(fields: [userId], references: [id])

  @@map("photo_comments")
}

model Notification {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  type      String   @db.VarChar(50)
  title     String   @db.VarChar(255)
  body      String?
  data      Json     @default("{}")
  read      Boolean  @default(false)
  sent      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read, createdAt(sort: Desc)])
  @@map("notifications")
}

model TimeEntry {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  obraId    String?  @map("obra_id") @db.Uuid
  type      String   @db.VarChar(10)
  timestamp DateTime @default(now())
  latitude  Decimal? @db.Decimal(10, 8)
  longitude Decimal? @db.Decimal(11, 8)
  address   String?
  photoUrl  String?  @map("photo_url")
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  obra Obra? @relation(fields: [obraId], references: [id])

  @@index([userId, timestamp(sort: Desc)])
  @@index([obraId, timestamp(sort: Desc)])
  @@map("time_entries")
}

model ChecklistTemplate {
  id              String   @id @default(uuid()) @db.Uuid
  name            String   @db.VarChar(255)
  type            String   @db.VarChar(50)
  segment         String   @db.VarChar(50)
  fase            String?  @db.VarChar(50)
  responsibleRole String?  @map("responsible_role") @db.VarChar(50)
  bluepaperDoc    Int?     @map("bluepaper_doc")
  createdAt       DateTime @default(now()) @map("created_at")

  items      ChecklistTemplateItem[]
  checklists Checklist[]

  @@map("checklist_templates")
}

model ChecklistTemplateItem {
  id          String  @id @default(uuid()) @db.Uuid
  templateId  String  @map("template_id") @db.Uuid
  title       String  @db.VarChar(500)
  description String?
  order       Int     @default(0)
  required    Boolean @default(true)

  template       ChecklistTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  checklistItems ChecklistItem[]

  @@index([templateId])
  @@map("checklist_template_items")
}

model Checklist {
  id          String    @id @default(uuid()) @db.Uuid
  obraId      String    @map("obra_id") @db.Uuid
  templateId  String?   @map("template_id") @db.Uuid
  type        String    @db.VarChar(50)
  segment     String    @db.VarChar(50)
  status      String    @default("em_andamento") @db.VarChar(50)
  createdBy   String?   @map("created_by") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at")
  completedAt DateTime? @map("completed_at")

  obra     Obra               @relation(fields: [obraId], references: [id], onDelete: Cascade)
  template ChecklistTemplate? @relation(fields: [templateId], references: [id])
  creator  User?              @relation("ChecklistCreator", fields: [createdBy], references: [id])
  items    ChecklistItem[]

  @@index([obraId])
  @@map("checklists")
}

model ChecklistItem {
  id             String    @id @default(uuid()) @db.Uuid
  checklistId    String    @map("checklist_id") @db.Uuid
  templateItemId String?   @map("template_item_id") @db.Uuid
  title          String    @db.VarChar(500)
  description    String?
  required       Boolean   @default(true)
  order          Int       @default(0)
  answer         String?   @db.VarChar(20)
  photoUrl       String?   @map("photo_url")
  observation    String?
  responsibleId  String?   @map("responsible_id") @db.Uuid
  answeredAt     DateTime? @map("answered_at")
  answeredBy     String?   @map("answered_by") @db.Uuid

  checklist    Checklist              @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  templateItem ChecklistTemplateItem? @relation(fields: [templateItemId], references: [id])
  responsible  User?                  @relation("ChecklistItemResponsible", fields: [responsibleId], references: [id])
  answerer     User?                  @relation("ChecklistItemAnswerer", fields: [answeredBy], references: [id])

  @@index([checklistId])
  @@map("checklist_items")
}

model CanteiroTemplate {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(255)
  version   Int      @default(1)
  createdAt DateTime @default(now()) @map("created_at")

  items      CanteiroTemplateItem[]
  checklists CanteiroChecklist[]

  @@map("canteiro_templates")
}

model CanteiroTemplateItem {
  id          String  @id @default(uuid()) @db.Uuid
  templateId  String  @map("template_id") @db.Uuid
  category    String  @db.VarChar(50)
  title       String  @db.VarChar(500)
  description String?
  order       Int     @default(0)
  required    Boolean @default(true)

  template       CanteiroTemplate       @relation(fields: [templateId], references: [id], onDelete: Cascade)
  checklistItems CanteiroChecklistItem[]

  @@index([templateId])
  @@map("canteiro_template_items")
}

model CanteiroChecklist {
  id         String    @id @default(uuid()) @db.Uuid
  obraId     String    @map("obra_id") @db.Uuid
  templateId String?   @map("template_id") @db.Uuid
  weekStart  DateTime  @map("week_start") @db.Date
  status     String    @default("em_andamento") @db.VarChar(50)
  createdBy  String?   @map("created_by") @db.Uuid
  approvedBy String?   @map("approved_by") @db.Uuid
  approvedAt DateTime? @map("approved_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  obra     Obra               @relation(fields: [obraId], references: [id], onDelete: Cascade)
  template CanteiroTemplate?  @relation(fields: [templateId], references: [id])
  creator  User?              @relation("CanteiroCreator", fields: [createdBy], references: [id])
  approver User?              @relation("CanteiroApprover", fields: [approvedBy], references: [id])
  items    CanteiroChecklistItem[]

  @@unique([obraId, weekStart])
  @@index([obraId])
  @@map("canteiro_checklists")
}

model CanteiroChecklistItem {
  id             String    @id @default(uuid()) @db.Uuid
  checklistId    String    @map("checklist_id") @db.Uuid
  templateItemId String?   @map("template_item_id") @db.Uuid
  title          String    @db.VarChar(500)
  category       String    @db.VarChar(50)
  order          Int       @default(0)
  required       Boolean   @default(true)
  answer         String?   @db.VarChar(20)
  photoUrl       String?   @map("photo_url")
  observation    String?
  answeredBy     String?   @map("answered_by") @db.Uuid
  answeredAt     DateTime? @map("answered_at")

  checklist    CanteiroChecklist      @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  templateItem CanteiroTemplateItem?  @relation(fields: [templateItemId], references: [id])
