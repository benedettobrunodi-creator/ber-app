  posX      Float      @default(0) @map("pos_x")
  posY      Float      @default(0) @map("pos_y")
  cor       String     @default("#6B7280") @db.VarChar(20)
  createdAt DateTime   @default(now()) @map("created_at")
  obra      Obra       @relation("ObraAmbientes", fields: [obraId], references: [id], onDelete: Cascade)
  planta    ObraPlanta? @relation(fields: [plantaId], references: [id], onDelete: SetNull)
  fotos     ObraFoto[]
  @@map("obra_ambientes")
}

model ObraFoto {
  id         String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  obraId     String       @db.Uuid @map("obra_id")
  ambienteId String?      @db.Uuid @map("ambiente_id")
  categoria  String       @default("geral") @db.VarChar(50)
  fileUrl    String       @map("file_url")
  legenda    String?
  tiradaPor  String?      @db.Uuid @map("tirada_por")
  tiradaEm   DateTime?    @db.Date @map("tirada_em")
  createdAt  DateTime     @default(now()) @map("created_at")
  obra       Obra         @relation("ObraFotos", fields: [obraId], references: [id], onDelete: Cascade)
  ambiente   ObraAmbiente? @relation(fields: [ambienteId], references: [id], onDelete: SetNull)
  autor      User?        @relation("FotoAutor", fields: [tiradaPor], references: [id], onDelete: SetNull)
  @@map("obra_fotos")
}

// ── MEDIÇÃO DE CONTRATO ──────────────────────────────────────────────────────

model Medicao {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  obraId        String    @db.Uuid @map("obra_id")
  numero        String    @db.VarChar(10)
  periodoInicio DateTime  @map("periodo_inicio") @db.Date
  periodoFim    DateTime  @map("periodo_fim") @db.Date
  status        String    @default("rascunho") @db.VarChar(20)
  criadoEm     DateTime  @default(now()) @map("criado_em")
  atualizadoEm DateTime  @updatedAt @map("atualizado_em")

  obra         Obra               @relation("ObraMedicoes", fields: [obraId], references: [id], onDelete: Cascade)
  lancamentos  MedicaoLancamento[]

  @@map("medicoes")
}

model MedicaoItem {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  obraId       String    @db.Uuid @map("obra_id")
  numero       String    @db.VarChar(20)
  descricao    String
  unidade      String?   @db.VarChar(20)
  quantidade   Decimal?  @map("quantidade") @db.Decimal(14, 4)
  valorOrcado  Decimal   @default(0) @map("valor_orcado") @db.Decimal(14, 2)
  tipo         String    @default("subitem") @db.VarChar(10)
  ordem        Int       @default(0)
  criadoEm    DateTime  @default(now()) @map("criado_em")

  obra         Obra               @relation("ObraMedicaoItens", fields: [obraId], references: [id], onDelete: Cascade)
  lancamentos  MedicaoLancamento[]

  @@map("medicao_itens")
}

model MedicaoLancamento {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  itemId              String    @db.Uuid @map("item_id")
  medicaoId           String    @db.Uuid @map("medicao_id")
  percentualExecutado Decimal   @default(0) @map("percentual_executado") @db.Decimal(5, 2)
  valorMedido         Decimal   @default(0) @map("valor_medido") @db.Decimal(14, 2)
  criadoEm           DateTime  @default(now()) @map("criado_em")
  atualizadoEm       DateTime  @updatedAt @map("atualizado_em")

  item    MedicaoItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  medicao Medicao     @relation(fields: [medicaoId], references: [id], onDelete: Cascade)

  @@unique([itemId, medicaoId])
  @@map("medicao_lancamentos")
}

// ─── DRE (Demonstrativo de Resultados) ──────────────────────────────────────

model DreValue {
  id        String   @id @default(uuid()) @db.Uuid
  rowKey    String   @map("row_key") @db.VarChar(20)
  colKey    String   @map("col_key") @db.VarChar(20)
  value     Float    @default(0)
  kpi       Float?
  updatedBy String?  @map("updated_by") @db.Uuid
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  updater   User?    @relation("DreUpdater", fields: [updatedBy], references: [id])

  @@unique([rowKey, colKey])
  @@map("dre_values")
}

// ─── ALOCAÇÃO DE MÃO DE OBRA ─────────────────────────────────────────────────

model Alocacao {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String?   @map("user_id") @db.Uuid
  recursoExternoId String?   @map("recurso_externo_id") @db.Uuid
  obraId           String    @map("obra_id") @db.Uuid
  cargoNaAlocacao  String    @default("gestor") @map("cargo_na_alocacao") @db.VarChar(20)
  fase             String    @default("ambas") @db.VarChar(20)
  dedicacaoPct     Int       @map("dedicacao_pct")
  dataInicio       DateTime? @map("data_inicio") @db.Date
  dataFim          DateTime? @map("data_fim") @db.Date
  createdAt        DateTime  @default(now()) @map("created_at")

  user           User?           @relation("AlocacaoUser", fields: [userId], references: [id], onDelete: Cascade)
  recursoExterno RecursoExterno? @relation("AlocacaoRecursoExterno", fields: [recursoExternoId], references: [id], onDelete: Cascade)
  obra           Obra            @relation("AlocacaoObra", fields: [obraId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([obraId])
  @@map("alocacoes")
}

model RecursoExterno {
  id          String     @id @default(uuid()) @db.Uuid
  nome        String     @db.VarChar(255)
  funcao      String     @db.VarChar(20)
  createdById String?    @map("created_by") @db.Uuid
  createdAt   DateTime   @default(now()) @map("created_at")

  createdBy User?      @relation("RecursoExternoCreator", fields: [createdById], references: [id], onDelete: SetNull)
  alocacoes Alocacao[] @relation("AlocacaoRecursoExterno")

  @@map("recursos_externos")
}

// ─── ESTEIRA DE ORÇAMENTOS ──────────────────────────────────────────────────

model Orcamento {
  id             String    @id @default(uuid()) @db.Uuid
  numero         String    @unique @db.VarChar(20)
  cliente        String    @db.VarChar(255)
  descricaoCurta String?   @map("descricao_curta") @db.VarChar(500)
  m2             Float?
  valorVenda     Decimal?  @map("valor_venda") @db.Decimal(14, 2)
  segmento       String?   @db.VarChar(50)
  estrategico    Boolean   @default(false)
  tipo           String    @default("NOVO") @db.VarChar(20)
  probabilidade  String?   @db.VarChar(20)
  status         String    @db.VarChar(50)
  categoria      String    @db.VarChar(50)
  dataInicio     DateTime? @map("data_inicio") @db.Date
  dataFim        DateTime? @map("data_fim") @db.Date
  dataEntrega    DateTime? @map("data_entrega") @db.Date
  responsavelId  String?   @map("responsavel_id") @db.Uuid
  observacoes    String?
  changeOrderDe  String?   @map("change_order_de") @db.Uuid
  createdById    String    @map("created_by_id") @db.Uuid
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @default(now()) @updatedAt @map("updated_at")

  responsavel User?               @relation("OrcResp", fields: [responsavelId], references: [id], onDelete: SetNull)
  createdBy   User                @relation("OrcCriador", fields: [createdById], references: [id])
  pai         Orcamento?          @relation("CO", fields: [changeOrderDe], references: [id], onDelete: SetNull)
  filhos      Orcamento[]         @relation("CO")
  historico   OrcamentoHistorico[]

  @@index([status])
  @@index([categoria])
  @@index([dataInicio, dataFim])
  @@map("orcamentos")
}

model OrcamentoHistorico {
  id          String    @id @default(uuid()) @db.Uuid
  orcamentoId String    @map("orcamento_id") @db.Uuid
  campo       String    @db.VarChar(100)
  valorAntigo String?   @map("valor_antigo")
  valorNovo   String?   @map("valor_novo")
  alteradoPor String    @map("alterado_por") @db.VarChar(255)
  alteradoEm  DateTime  @default(now()) @map("alterado_em")

  orcamento Orcamento @relation(fields: [orcamentoId], references: [id], onDelete: Cascade)

  @@index([orcamentoId])
  @@map("orcamento_historico")
}
